# Retail Analytics Copilot — Environment Variables
# Copy this file to .env and fill in your values.

# Ollama model name (default: phi3.5:3.8b-mini-instruct-q4_K_M)
OLLAMA_MODEL=phi3.5:3.8b-mini-instruct-q4_K_M

# Path to Northwind SQLite database
DB_PATH=data/northwind.sqlite

# Path to documents directory
DOCS_DIR=docs

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# DSPy optimization: enable or disable (true/false)
RUN_OPTIMIZATION=true
