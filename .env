# ─── Model Backend ────────────────────────────────────────────────────────────
# True  = استخدم Ollama محلياً (كما هو الكود الأصلي بدون تغيير)
# False = استخدم Ollama عبر Google Colab + Ngrok (notebooks منفصلة)
LOCAL_MODELS=True

# ─── Local Models (LOCAL_MODELS=True) ────────────────────────────────────────
# اسم الموديل المستخدم محلياً مع Ollama
OLLAMA_MODEL=phi3.5:3.8b-mini-instruct-q4_K_M

# ─── Remote Models via Ngrok (LOCAL_MODELS=False) ────────────────────────────
# روابط Ngrok بعد تشغيل كل notebook على Google Colab
# كل موديل له notebook منفصلة وتضع رابط Ngrok هنا بعد تشغيلها

# موديل Router (تصنيف السؤال: rag | sql | hybrid)
NGROK_ROUTER_MODEL=phi3.5:3.8b-mini-instruct-q4_K_M
NGROK_ROUTER_URL=https://your-router-ngrok-url.ngrok-free.app

# موديل NL2SQL (تحويل السؤال لـ SQL)
NGROK_NL2SQL_MODEL=gemma2:9b-instruct-q5_0
NGROK_NL2SQL_URL=https://your-nl2sql-ngrok-url.ngrok-free.app

# موديل Synthesis (توليد الإجابة النهائية)
NGROK_SYNTHESIS_MODEL=gemma2:9b-instruct-q5_0
NGROK_SYNTHESIS_URL=https://your-synthesis-ngrok-url.ngrok-free.app

# موديل Planner (استخراج القيود والتواريخ)
NGROK_PLANNER_MODEL=phi3.5:3.8b-mini-instruct-q4_K_M
NGROK_PLANNER_URL=https://your-planner-ngrok-url.ngrok-free.app

# ─── Database & Docs ──────────────────────────────────────────────────────────
DB_PATH=data/northwind.sqlite
DOCS_DIR=docs

# ─── Logging & Optimization ───────────────────────────────────────────────────
LOG_LEVEL=INFO
RUN_OPTIMIZATION=true
